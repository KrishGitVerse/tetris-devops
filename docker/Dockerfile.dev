# =============================================================
# Development Dockerfile
# =============================================================
# Used for local development with hot-reload
# NOT used in production or CI/CD
FROM node:20-alpine

LABEL app="tetris-devops"
LABEL stage="development"

# Install bash for debugging convenience
RUN apk add --no-cache bash

WORKDIR /app

COPY app/package*.json ./

# Install ALL dependencies including devDependencies
RUN npm ci --frozen-lockfile

# We do NOT copy source here — we mount it as a volume instead
# This means file changes on your host instantly appear in container
# (hot-reload works!)

EXPOSE 3000
EXPOSE 3001

ENV NODE_ENV=development

# Start React development server
CMD ["npm", "run", "start:dev"]