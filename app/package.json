{
  "name": "tetris-devops",
  "version": "1.0.0",
  "description": "Production-grade Tetris game with full DevOps pipeline",
  "private": true,
  "scripts": {
    "start": "node src/server/index.js",
    "start:dev": "react-scripts start",
    "build": "react-scripts build",
    "test": "jest --watchAll=false",
    "test:coverage": "jest --watchAll=false --coverage",
    "server": "node src/server/index.js",
    "lint": "eslint src/ --ext .js,.jsx"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/src/__mocks__/styleMock.js"
    },
    "testMatch": [
      "<rootDir>/src/__tests__/**/*.test.js",
      "<rootDir>/src/__tests__/**/*.test.jsx"
    ],
    "collectCoverageFrom": [
      "src/utils/gameHelpers.js",
      "src/server/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 40,
        "functions": 40,
        "lines": 40,
        "statements": 40
      }
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/build/"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version"
    ]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.1",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "superagent": "^8.1.2",
    "supertest": "^6.3.3"
  }
}
